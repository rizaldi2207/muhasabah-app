{
  "name": "muhasabah-harian",
  "version": "1.0.0",
  "private": true,
  "description": "Aplikasi tracking kegiatan harian (muhasabah) dengan dashboard dan pengingat",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "npm --prefix client run dev",
    "start": "node server/index.js",
    "build:client": "npm --prefix client run build",
    "seed": "node server/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9"
  }
}
